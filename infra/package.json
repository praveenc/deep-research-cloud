{
  "name": "@deep-research/infra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all --require-approval broadening",
    "deploy:data": "cdk deploy DeepResearch-Data-*",
    "deploy:mcp": "cdk deploy DeepResearch-McpServers-*",
    "deploy:api": "cdk deploy DeepResearch-Api-*",
    "deploy:agent": "cdk deploy DeepResearch-AgentRuntime-*",
    "deploy:frontend": "cdk deploy DeepResearch-Frontend-*",
    "diff": "cdk diff",
    "destroy": "cdk destroy --all"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.237.0",
    "@aws-cdk/aws-bedrock-agentcore-alpha": "^2.237.1-alpha.0",
    "constructs": "^10.4.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.7.0",
    "aws-cdk": "^2.237.0"
  }
}
